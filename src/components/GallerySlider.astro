---

<div class="gallery-slider-wrapper relative w-full py-8 overflow-hidden">
    <!-- Slider Container -->
    <div
        id="gallery-slider"
        class="flex transition-transform duration-500 ease-out cursor-grab active:cursor-grabbing px-6 lg:px-0"
    >
        {
            images.map((src, index) => (
                <div
                    class="gallery-item flex-none w-full md:w-1/3 p-2 transition-all duration-500"
                    data-index={index}
                >
                    <!-- 
                         PENGATURAN KELENGKUNGAN GAMBAR (ROUNDED CORNERS)
                         Ubah 'rounded-2xl' menjadi 'rounded-lg', 'rounded-3xl', atau 'rounded-none' 
                         untuk mengatur kelengkungan ujung gambar.
                    -->
                    <div class="relative aspect-[4/5] bg-charcoal/10 overflow-hidden shadow-lg border border-white/5 rounded-2xl">
                        <img
                            src={src}
                            alt={`Gallery Image ${index + 1}`}
                            class="w-full h-full object-cover select-none pointer-events-none"
                            draggable="false"
                        />
                    </div>
                </div>
            ))
        }
    </div>

    <!-- Navigation Dots -->
    <div class="flex justify-center gap-3 mt-10">
        {
            images.map((_, index) => (
                <div
                    class="gallery-dot w-2 h-2 rounded-full bg-gold/20 transition-all duration-300 cursor-pointer"
                    data-index={index}
                />
            ))
        }
    </div>
</div>

<script>
    function initNormalSlider() {
        const slider = document.getElementById("gallery-slider");
        const items = document.querySelectorAll(".gallery-item");
        const dots = document.querySelectorAll(".gallery-dot");

        if (!slider || items.length === 0) return;

        let currentIndex = 0;
        let startX = 0;
        let currentTranslate = 0;
        let prevTranslate = 0;
        let isDragging = false;
        let animationID = 0;

        function getVisibleCount() {
            return window.innerWidth >= 768 ? 3 : 1;
        }

        function getMaxIndex() {
            return Math.max(0, items.length - getVisibleCount());
        }

        function updateSlider() {
            const visibleCount = getVisibleCount();
            const itemWidth = (items[0] as HTMLElement).offsetWidth;

            // Limit current index
            if (currentIndex > getMaxIndex()) currentIndex = getMaxIndex();

            currentTranslate = -currentIndex * itemWidth;
            prevTranslate = currentTranslate;

            slider!.style.transform = `translateX(${currentTranslate}px)`;

            // Update dots
            dots.forEach((dot, index) => {
                const isActive = index === currentIndex;
                (dot as HTMLElement).style.backgroundColor = isActive
                    ? "#b08d57"
                    : "rgba(176, 141, 87, 0.2)";
                (dot as HTMLElement).style.width = isActive ? "24px" : "8px";
            });
        }

        function handleDragStart(e: any) {
            isDragging = true;
            startX = e.type.includes("mouse") ? e.pageX : e.touches[0].clientX;
            slider!.style.transition = "none";
            animationID = requestAnimationFrame(animation);
        }

        function handleDragMove(e: any) {
            if (!isDragging) return;
            
            const currentX = e.type.includes("mouse")
                ? e.pageX
                : e.touches[0].clientX;
            const currentY = e.type.includes("mouse")
                ? e.pageY
                : e.touches[0].clientY;

            // Calculate movement diff
            const diffX = currentX - startX;
            const diffY = currentY - (e.type.includes("mouse") ? 0 : e.touches[0].clientY); // Simple Y check
            
            // If horizontal movement is significantly more than vertical, prevent page scroll
            if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 10) {
                if (e.cancelable) e.preventDefault();
            }

            currentTranslate = prevTranslate + diffX;
        }

        function handleDragEnd() {
            if (!isDragging) return;
            isDragging = false;
            cancelAnimationFrame(animationID);
            slider!.style.transition = "transform 0.5s cubic-bezier(0.2, 1, 0.3, 1)";

            const movedBy = currentTranslate - prevTranslate;
            const threshold = 50;

            if (movedBy < -threshold && currentIndex < getMaxIndex()) {
                currentIndex += 1;
            } else if (movedBy > threshold && currentIndex > 0) {
                currentIndex -= 1;
            }

            updateSlider();
        }

        function animation() {
            slider!.style.transform = `translateX(${currentTranslate}px)`;
            if (isDragging) requestAnimationFrame(animation);
        }

        // Event Listeners - Use non-passive for touchmove to allow preventing scroll when swiping
        slider.addEventListener("touchstart", handleDragStart, { passive: true });
        slider.addEventListener("touchmove", handleDragMove, { passive: false });
        slider.addEventListener("touchend", handleDragEnd);

        slider.addEventListener("mousedown", handleDragStart);
        window.addEventListener("mousemove", (e) => {
            if (isDragging) handleDragMove(e);
        });
        window.addEventListener("mouseup", handleDragEnd);

        // Dot Clicks
        dots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
                currentIndex = Math.min(index, getMaxIndex());
                updateSlider();
            });
        });

        // Initialize
        updateSlider();
        window.addEventListener("resize", updateSlider);
    }

    initNormalSlider();
    document.addEventListener("astro:page-load", initNormalSlider);
</script>

<style>
    /* Prevent text selection and image dragging during swipe */
    .gallery-slider-wrapper {
        user-select: none;
        -webkit-user-drag: none;
    }
</style>
