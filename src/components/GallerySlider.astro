---

<!-- SPACING: Section vertical padding -->
<div class="gallery-slider-wrapper relative w-full py-8 overflow-hidden">
    <!-- Slider Container -->
    <!-- SPACING: Container padding for mobile -->
    <div
        id="gallery-slider"
        class="flex cursor-grab active:cursor-grabbing px-6 lg:px-0"
        style="will-change: transform; transform: translate3d(0,0,0);"
    >
        {
            images.map((src, index) => (
                <div
                    class="gallery-item flex-none w-full md:w-1/3 p-2 transition-all duration-500"
                    data-index={index}
                >
                    <!-- 
                         PENGATURAN KELENGKUNGAN GAMBAR (ROUNDED CORNERS)
                         Ubah 'rounded-2xl' menjadi 'rounded-lg', 'rounded-3xl', atau 'rounded-none' 
                         untuk mengatur kelengkungan ujung gambar.
                    -->
                    <div class="relative aspect-4/5 bg-charcoal/10 overflow-hidden shadow-lg border border-white/5 rounded-2xl">
                        <img
                            src={src}
                            alt={`Gallery Image ${index + 1}`}
                            class="w-full h-full object-cover select-none pointer-events-none"
                            draggable="false"
                        />
                    </div>
                </div>
            ))
        }
    </div>

    <!-- Navigation Dots -->
    <!-- SPACING: Dots container top margin and gap -->
    <div class="flex justify-center gap-3 mt-10">
        {
            images.map((_, index) => (
                <div
                    class="gallery-dot w-2 h-2 rounded-full bg-gold/20 transition-all duration-300 cursor-pointer"
                    data-index={index}
                />
            ))
        }
    </div>
</div>

<script>
    function initNormalSlider() {
        const slider = document.getElementById("gallery-slider");
        const items = document.querySelectorAll(".gallery-item");
        const dots = document.querySelectorAll(".gallery-dot");

        if (!slider || items.length === 0) return;

        let currentIndex = 0;
        let startX = 0;
        let startY = 0;
        let currentTranslate = 0;
        let prevTranslate = 0;
        let isDragging = false;
        let animationID = 0;
        let startTime = 0;

        function getVisibleCount() {
            const width = window.innerWidth;
            if (width >= 1024) return 3;
            if (width >= 768) return 2;
            return 1;
        }

        function getMaxIndex() {
            return Math.max(0, items.length - getVisibleCount());
        }

        function updateSlider(withTransition = true) {
            const firstItem = items[0] as HTMLElement;
            if (!firstItem) return;
            
            const itemWidth = firstItem.offsetWidth;
            const maxIndex = getMaxIndex();
            
            if (currentIndex > maxIndex) currentIndex = 0;
            if (currentIndex < 0) currentIndex = maxIndex;

            currentTranslate = -currentIndex * itemWidth;
            prevTranslate = currentTranslate;

            slider!.style.transition = withTransition ? "transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)" : "none";
            slider!.style.transform = `translate3d(${currentTranslate}px, 0, 0)`;

            dots.forEach((dot, index) => {
                const isActive = index === currentIndex;
                const dotElement = dot as HTMLElement;
                dotElement.style.backgroundColor = isActive ? "#b08d57" : "rgba(176, 141, 87, 0.2)";
                dotElement.style.width = isActive ? "24px" : "8px";
            });
        }

        function handleDragStart(e: any) {
            isDragging = true;
            startTime = Date.now();
            const touch = e.type.includes("mouse") ? e : e.touches[0];
            startX = touch.pageX;
            startY = touch.pageY;
            
            slider!.style.transition = "none";
            slider!.style.cursor = "grabbing";
            cancelAnimationFrame(animationID);
        }

        function handleDragMove(e: any) {
            if (!isDragging) return;
            
            const touch = e.type.includes("mouse") ? e : e.touches[0];
            const currentX = touch.pageX;
            const currentY = touch.pageY;

            const diffX = currentX - startX;
            const diffY = currentY - startY;
            
            if (Math.abs(diffX) > Math.abs(diffY)) {
                if (e.cancelable) e.preventDefault();
                currentTranslate = prevTranslate + diffX;
                slider!.style.transform = `translate3d(${currentTranslate}px, 0, 0)`;
            } else if (Math.abs(diffY) > 10) {
                isDragging = false;
                slider!.style.cursor = "grab";
            }
        }

        function handleDragEnd() {
            if (!isDragging) return;
            isDragging = false;
            slider!.style.cursor = "grab";

            const movedBy = currentTranslate - prevTranslate;
            const timeElapsed = Date.now() - startTime;
            const velocity = Math.abs(movedBy) / timeElapsed;
            const threshold = 50;
            const maxIndex = getMaxIndex();

            if (movedBy < -threshold || (velocity > 0.5 && movedBy < 0)) {
                if (currentIndex >= maxIndex) currentIndex = 0;
                else currentIndex += 1;
            } else if (movedBy > threshold || (velocity > 0.5 && movedBy > 0)) {
                if (currentIndex <= 0) currentIndex = maxIndex;
                else currentIndex -= 1;
            }

            updateSlider();
        }

        // Use precise event handling
        slider.addEventListener("mousedown", handleDragStart);
        slider.addEventListener("touchstart", handleDragStart, { passive: true });

        window.addEventListener("mousemove", (e) => isDragging && handleDragMove(e), { passive: false });
        window.addEventListener("touchmove", (e) => isDragging && handleDragMove(e), { passive: false });

        window.addEventListener("mouseup", handleDragEnd);
        window.addEventListener("touchend", handleDragEnd);

        dots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
                currentIndex = Math.min(index, getMaxIndex());
                updateSlider();
            });
        });

        const setup = () => updateSlider(false);
        setup();
        setTimeout(setup, 100);

        let resizeTimer: any;
        window.addEventListener("resize", () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(setup, 150);
        });
    }

    initNormalSlider();
    document.addEventListener("astro:page-load", initNormalSlider);
</script>

<style>
    .gallery-slider-wrapper {
        user-select: none;
        touch-action: pan-y;
        overflow: hidden;
    }

    #gallery-slider {
        display: flex;
        touch-action: pan-y;
        -webkit-user-drag: none;
        /* Hardware acceleration */
        transform-style: preserve-3d;
        backface-visibility: hidden;
    }

    .gallery-item {
        /* Anti-jitter properties */
        backface-visibility: hidden;
        transform: translateZ(0);
        flex-shrink: 0;
    }

    .gallery-item img {
        pointer-events: none;
        -webkit-user-drag: none;
        user-select: none;
    }
</style>
