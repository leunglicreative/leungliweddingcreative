<script is:inline>
    // Carousel Logic
    const slides = document.querySelectorAll(".carousel-slide");
    const dots = document.querySelectorAll(".carousel-dot");
    let currentSlide = 0;
    let slideInterval;

    function showSlide(index) {
        slides.forEach((slide, i) => {
            slide.style.opacity = i === index ? "1" : "0";
        });
        dots.forEach((dot, i) => {
            if (i === index) {
                dot.style.backgroundColor = "rgba(249, 246, 240, 0.8)";
                dot.style.width = "24px";
            } else {
                dot.style.backgroundColor = "rgba(249, 246, 240, 0.2)";
                dot.style.width = "6px";
            }
        });
    }

    function nextSlide() {
        currentSlide = (currentSlide + 1) % slides.length;
        showSlide(currentSlide);
    }

    function prevSlide() {
        currentSlide = (currentSlide - 1 + slides.length) % slides.length;
        showSlide(currentSlide);
    }

    function startInterval() {
        slideInterval = setInterval(nextSlide, 3000);
    }

    // Auto Swipe 3s
    startInterval();

    // Manual Swipe Logic
    const carouselContainer = document.getElementById("hero-carousel");
    let touchStartX = 0;
    let touchEndX = 0;

    if (carouselContainer) {
        carouselContainer.addEventListener(
            "touchstart",
            (e) => {
                touchStartX = e.changedTouches[0].screenX;
                clearInterval(slideInterval);
            },
            { passive: true },
        );

        carouselContainer.addEventListener(
            "touchend",
            (e) => {
                touchEndX = e.changedTouches[0].screenX;
                const threshold = 50;
                if (touchEndX < touchStartX - threshold) nextSlide();
                if (touchEndX > touchStartX + threshold) prevSlide();
                startInterval();
            },
            { passive: true },
        );
    }

    // Save Date Logic - Native ICS
    const saveDateBtn = document.getElementById("save-date-btn");
    if (saveDateBtn) {
        saveDateBtn.addEventListener("click", () => {
            const title = "Pernikahan Mempelai Pria & Wanita";
            const location = "The Grand Ballroom, Luxury Hotel, Jakarta";
            const description =
                "Acara resepsi pernikahan Mempelai Pria & Wanita. Mohon doa restu.";
            const startDate = "20260324T090000";
            const endDate = "20260324T130000";

            // Build ICS Content
            const icsContent = [
                "BEGIN:VCALENDAR",
                "VERSION:2.0",
                "PRODID:-//Wedding Invitation//ID",
                "BEGIN:VEVENT",
                `DTSTART:${startDate}`,
                `DTEND:${endDate}`,
                `SUMMARY:${title}`,
                `LOCATION:${location}`,
                `DESCRIPTION:${description}`,
                "END:VEVENT",
                "END:VCALENDAR",
            ].join("\r\n");

            const blob = new Blob([icsContent], {
                type: "text/calendar;charset=utf-8",
            });
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.setAttribute("download", "pernikahan.ics");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        });
    }
</script>
