<!-- Background Music Element Only (No UI) -->
<audio id="main-audio-el" loop preload="auto">
    <source src="/sound/janjisuci.mp3" type="audio/mpeg" />
</audio>

<script is:inline>
    (function () {
        const audio = document.getElementById("main-audio-el");

        function startMusic() {
            if (audio && audio.paused) {
                audio
                    .play()
                    .then(() => {
                        console.log(
                            "Music started successfully after opening invitation",
                        );
                    })
                    .catch((err) => {
                        console.log("Music playback failed", err);
                    });
            }
        }

        // Listen for the custom event triggered from index.astro
        window.addEventListener("start-wedding-music", startMusic);

        // Fallback: If page is reloaded and invitation was already marked as opened (if we ever use persistence again)
        // For now, based on user logic, we only start on button click.
    })();
</script>
