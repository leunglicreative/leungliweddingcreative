---

---

<!-- SPACING: Section padding and scroll offset -->
<section id="place" class="px-6 pt-24 pb-20 lg:pt-32 lg:pb-32 scroll-mt-5">
    <!-- SPACING: Card container rounded corners and max width -->
    <div
        class="bg-white rounded-32 shadow-sm border border-charcoal/5 overflow-hidden max-w-lg lg:max-w-4xl mx-auto lg:flex duration-300"
    >
        <!-- SPACING: Image height for mobile/desktop -->
        <div
            class="w-full lg:w-1/2 h-56 lg:h-auto bg-center bg-cover bg-[url('/assets/makkah.jpg')]"
        >
        </div>

        <!-- SPACING: Text content container padding -->
        <div
            class="p-8 lg:p-12 lg:w-1/2 flex flex-col justify-center text-center lg:text-left"
        >
            <!-- SPACING: Subtitle bottom margin -->
            <p class="text-gold font-serif italic text-xl lg:text-2xl mb-8">
                The Wedding Ceremony
            </p>

            <!-- SPACING: Info items container gap and bottom margin -->
            <div class="space-y-6 mb-10">
                <!-- SPACING: Individual info item gap -->
                <div
                    class="flex flex-col lg:flex-row lg:items-center lg:gap-4 items-center"
                >
                    <!-- SPACING: Icon bottom margin for mobile -->
                    <span
                        class="material-symbols-outlined text-gold text-lg lg:text-2xl mb-1 lg:mb-0"
                        >calendar_month</span
                    >
                    <div>
                        <p
                            class="text-charcoal text-sm lg:text-base font-medium"
                        >
                            Tuesday, 24 March 2026
                        </p>
                        <p
                            class="text-charcoal/50 text-xs lg:text-sm text-balance"
                        >
                            At 09:00 AM onwards
                        </p>
                    </div>
                </div>

                <!-- SPACING: Individual info item gap -->
                <div
                    class="flex flex-col lg:flex-row lg:items-center lg:gap-4 items-center"
                >
                    <!-- SPACING: Icon bottom margin for mobile -->
                    <span
                        class="material-symbols-outlined text-gold text-lg lg:text-2xl mb-1 lg:mb-0"
                        >location_on</span
                    >
                    <div>
                        <p
                            class="text-charcoal text-sm lg:text-base font-medium"
                        >
                            Makkah, Masjidil Haram
                        </p>
                        <p
                            class="text-charcoal/50 text-xs lg:text-sm text-balance"
                        >
                            Makkah, Saudi Arabia
                        </p>
                    </div>
                </div>
            </div>

            <!-- SPACING: Button vertical padding -->
            <a
                href="https://maps.app.goo.gl/iUAM6Usc35SReEp78"
                target="_blank"
                class="block w-full py-4 lg:py-5 border border-charcoal text-charcoal rounded-full text-[10px] lg:text-xs font-bold tracking-[0.2em] uppercase transition-all hover:bg-charcoal hover:text-cream text-center no-underline"
            >
                Open Maps Location
            </a>
        </div>
    </div>
</section>
