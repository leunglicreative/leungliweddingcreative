---

---

<div
    id="invitation-modal"
    class="fixed inset-0 z-100 flex items-center justify-center overflow-hidden"
>
    <!-- Solid Background Panels for "Door Opening" Effect -->
    <div
        id="modal-panel-top"
        class="absolute inset-x-0 top-0 h-1/2 bg-[#f9f6f0] border-bottom border-charcoal/5 transition-transform duration-1200 ease-in-out z-10"
    >
    </div>
    <div
        id="modal-panel-bottom"
        class="absolute inset-x-0 bottom-0 h-1/2 bg-[#f9f6f0] border-top border-charcoal/5 transition-transform duration-1200 ease-in-out z-10"
    >
    </div>

    <!-- Soft Grain Texture Overlay -->
    <div
        class="absolute inset-0 z-11 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/natural-paper.png')]"
    >
    </div>

    <!-- Overlay Card -->
    <div
        id="modal-card"
        class="relative z-20 p-10 lg:p-14 max-w-[90%] w-[380px] lg:w-[500px] bg-[#4a3728] rounded-32 border border-gold/20 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] text-center transition-all duration-1000 ease-in-out"
    >
        <!-- Elegant Border Decoration -->
        <div
            class="absolute inset-4 border border-gold/20 rounded-24 pointer-events-none"
        >
        </div>
        <div
            class="absolute inset-[18px] border border-gold/10 rounded-20 pointer-events-none"
        >
        </div>

        <div class="relative z-10">
            <p
                class="text-gold uppercase tracking-[0.6em] text-[9px] mb-6 font-bold"
            >
                The Wedding Of
            </p>

            <h1
                class="text-cream font-serif italic text-4xl lg:text-5xl mb-4 leading-tight tracking-tight drop-shadow-sm"
            >
                Umar & Mempelai Wanita
            </h1>

            <div class="flex items-center justify-center gap-4 my-8">
                <div
                    class="h-[1px] w-12 bg-linear-to-r from-transparent to-gold/40"
                >
                </div>
                <div class="w-2 h-2 rounded-full border border-gold/40"></div>
                <div
                    class="h-[1px] w-12 bg-linear-to-l from-transparent to-gold/40"
                >
                </div>
            </div>

            <div class="space-y-2 mb-10">
                <p
                    class="text-gold/40 text-[9px] uppercase tracking-[0.3em] font-semibold"
                >
                    Special Invitation for
                </p>
                <div class="py-2">
                    <p
                        class="text-cream font-bold text-xl lg:text-2xl tracking-wide italic leading-relaxed"
                    >
                        Bapak/Ibu/Saudara/i
                    </p>
                </div>
                <p
                    class="text-cream/60 text-[10px] uppercase tracking-[0.15em] leading-relaxed pt-3 px-4"
                >
                    Kami sangat berharap Anda dapat bergabung dalam sukacita
                    kami.
                </p>
            </div>

            <button
                id="open-invitation-btn"
                class="group w-full bg-cream text-charcoal py-5 rounded-full text-[10px] font-bold tracking-[0.4em] uppercase transition-all duration-500 shadow-xl hover:bg-gold hover:text-charcoal active:scale-95 cursor-pointer flex items-center justify-center gap-3"
            >
                <span>Buka Undangan</span>
                <!-- <span
                    class="material-symbols-outlined text-base group-hover:rotate-12 transition-transform"
                    >mail</span
                > -->
            </button>
        </div>
    </div>
</div>

<style>
    /* Custom spacing classes */
    .rounded-32 {
        border-radius: 32px;
    }
    .rounded-24 {
        border-radius: 24px;
    }
    .rounded-20 {
        border-radius: 20px;
    }

    body.modal-active {
        overflow: hidden !important;
    }

    #main-content.content-blur {
        filter: blur(15px);
        transform: scale(0.98);
        transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Animation classes triggered by JS */
    #invitation-modal.opened #modal-panel-top {
        transform: translateY(-100%);
    }

    #invitation-modal.opened #modal-panel-bottom {
        transform: translateY(100%);
    }

    #invitation-modal.opened #modal-card {
        opacity: 0;
        transform: scale(1.1);
        filter: blur(10px);
        pointer-events: none;
    }
</style>
