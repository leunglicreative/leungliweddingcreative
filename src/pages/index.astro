---
import "../styles/global.css";
import Hero from "../components/Hero.astro";
import Details from "../components/Details.astro";
import Quotes from "../components/Quotes.astro";
import Guestbook from "../components/Guestbook.astro";
import InvitationModal from "../components/InvitationModal.astro";
import FloatingDecor from "../components/FloatingDecor.astro";
import GallerySlider from "../components/GallerySlider.astro";
import LoveStory from "../components/LoveStory.astro";
import WeddingGift from "../components/WeddingGift.astro";
import Footer from "../components/Footer.astro";
import MusicPlayer from "../components/MusicPlayer.astro";
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>The Wedding of Mempelai Pria & Wanita</title>
		<!-- Add metadata for better visual integration on mobile -->
		<meta name="theme-color" content="#f9f6f0" />
	</head>

	<body
		class="font-display antialiased bg-cream text-charcoal modal-active"
		oncontextmenu="return false"
		oncopy="return false"
		oncut="return false"
	>
		<InvitationModal />

		<main
			id="main-content"
			class="relative flex h-auto min-h-svh w-full flex-col overflow-x-hidden content-blur"
		>
			<!-- Hero Section - Background is static, content reveals -->
			<Hero />

			<!-- Formal Greeting Section -->
			<div class="reveal">
				<!-- SPACING: Section vertical padding -->
				<div class="max-w-4xl mx-auto text-center py-20 px-6">
					<!-- SPACING: Header bottom margin -->
					<h2
						class="text-gold uppercase tracking-[0.4em] text-[10px] lg:text-xs font-bold mb-10"
					>
						The Wedding Invitation
					</h2>
					<p
						class="text-gold font-serif text-lg lg:text-2xl leading-relaxed mb-16 italic opacity-90 px-4 lg:px-12"
					>
						"Maha Suci Allah yang telah menciptakan makhluk-Nya
						berpasang-pasangan. Ya Allah, perkenankanlah kami
						merangkaikan kasih sayang yang Kau ciptakan dalam
						pernikahan putra-putri kami."
					</p>

					<div class="flex flex-col items-center gap-12">
						<!-- Groom -->
						<div class="flex flex-col items-center">
							<h3
								class="text-4xl lg:text-6xl font-serif text-charcoal mb-4 italic leading-tight"
							>
								Umar
							</h3>
							<p
								class="text-charcoal/60 text-[11px] lg:text-xs tracking-widest leading-loose font-medium uppercase"
							>
								Putra dari Keluarga Bpk. Nama Ayah & Ibu
							</p>
						</div>

						<!-- Separator -->
						<!-- SPACING: Separator gap -->
						<div class="flex items-center gap-4 w-full max-w-xs">
							<div class="h-px flex-1 bg-gold/30"></div>
							<span
								class="text-2xl lg:text-3xl font-serif text-gold italic"
								>&</span
							>
							<div class="h-px flex-1 bg-gold/30"></div>
						</div>

						<!-- Bride -->
						<div class="flex flex-col items-center">
							<h3
								class="text-4xl lg:text-6xl font-serif text-charcoal mb-4 italic leading-tight"
							>
								Mempelai Wanita
							</h3>
							<p
								class="text-charcoal/60 text-[11px] lg:text-xs tracking-widest leading-loose font-medium uppercase"
							>
								Putri dari Keluarga Bpk. Nama Ayah & Ibu
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="reveal">
				<!-- Horizontal Highlight Image - Now Swipeable Gallery -->
				<GallerySlider />
			</div>

			<div class="reveal">
				<!-- Story Section -->
				<LoveStory />
			</div>

			<div class="reveal"><Quotes /></div>
			<div class="reveal"><Details /></div>
			<div class="reveal"><WeddingGift /></div>
			<div class="reveal"><Guestbook /></div>
			<Footer />
			<MusicPlayer />
			<FloatingDecor />
		</main>

		<script is:inline>
			const observerOptions = {
				root: null,
				rootMargin: "0px",
				threshold: 0.1,
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("active");
						observer.unobserve(entry.target);
					}
				});
			}, observerOptions);

			function initReveal() {
				document.querySelectorAll(".reveal").forEach((el) => {
					observer.observe(el);
				});
			}

			// Handle Invitation Open
			const modal = document.getElementById("invitation-modal");
			const openBtn = document.getElementById("open-invitation-btn");
			const mainContent = document.getElementById("main-content");
			let isOpened = false;

			function openInvitation() {
				if (isOpened) return;
				isOpened = true;

				// Save state to session storage
				sessionStorage.setItem("invitation_opened", "true");

				document.body.classList.remove("modal-active");
				if (mainContent) {
					mainContent.classList.remove("content-blur");
					mainContent.style.filter = "none";
					mainContent.style.transform = "none";
				}

				// Trigger music playback
				window.dispatchEvent(new Event("start-wedding-music"));

				if (modal) {
					modal.classList.add("opened");

					setTimeout(() => {
						modal.style.display = "none";
						initReveal(); // Start animations after opening
						window.dispatchEvent(new Event("resize"));
					}, 1200); // Match with the 1.2s panel transition
				}
			}

			// Check if already opened before in this session
			const hasOpened =
				sessionStorage.getItem("invitation_opened") === "true";

			if (hasOpened) {
				isOpened = true;
				document.body.classList.remove("modal-active");
				if (mainContent) {
					mainContent.classList.remove("content-blur");
					mainContent.style.filter = "none";
					mainContent.style.transform = "none";
				}
				if (modal) modal.style.display = "none";

				// Re-init reveal animations
				initReveal();

				// Try to start music (might be blocked by browser until first click)
				window.dispatchEvent(new Event("start-wedding-music"));
			} else {
				if (openBtn) {
					openBtn.addEventListener("click", openInvitation);
				}
			}
		</script>
	</body>
</html>
